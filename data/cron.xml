<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Atualiza espelhos e status das cobranças (GET /v3/payments) para colaboradores com vínculo Asaas. -->
    <record id="ir_cron_sync_asaas_payments" model="ir.cron">
        <field name="name">Wellhub: atualizar status das cobranças Asaas</field>
        <field name="model_id" ref="model_wellhub_collaborator"/>
        <field name="state">code</field>
        <field name="code">model.cron_update_asaas_payment_statuses()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
