<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_wellhub_signup_activation" model="mail.template">
            <field name="name">Wellhub: confirmar inscrição de colaborador</field>
            <field name="model_id" ref="model_wellhub_collaborator"/>
            <field name="subject">Confirme sua inscrição Wellhub</field>
            <field name="email_from">{{ object.company_id.email_formatted or user.email_formatted or '' }}</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="description">Enviado após o cadastro no formulário público de inscrição.</field>
            <field name="body_html" type="html">
<div style="font-family: sans-serif; font-size: 14px; color: #333;">
    <p>Olá <t t-out="object.name or ''"/>,</p>
    <p>Recebemos o seu cadastro no Wellhub. Clique no botão abaixo para confirmar o e-mail e ativar a sua assinatura.</p>
    <p style="margin: 24px 0;">
        <a t-att-href="object.signup_mail_activation_url"
           style="background-color:#714B67;color:#fff;padding:12px 20px;text-decoration:none;border-radius:4px;display:inline-block;">
            Ativar inscrição
        </a>
    </p>
    <p style="font-size: 12px; color: #666;">O link é válido por 48 horas.</p>
    <p style="font-size: 12px; color: #666;">Se não solicitou este cadastro, ignore este e-mail.</p>
    <p>— <t t-out="object.company_id.name or ''"/></p>
</div>
            </field>
        </record>
    </data>
</odoo>
